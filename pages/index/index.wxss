/* pages/index/index.wxss - Hugo Shell Retro: User Dashboard */

/* User Profile Card */
.user-card {
  margin-top: 32rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 32rpx 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border: 2rpx solid #00ff00;
  margin-right: 32rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #00ff00;
  display: block;
  margin-bottom: 16rpx;
}

.username::before {
  content: 'user@mahjong:~$ cat profile.txt\n';
  font-size: 24rpx;
  display: block;
  margin-bottom: 8rpx;
  color: #00ff00;
}

.stats {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #00ff00;
  padding: 10rpx 20rpx;
  background: transparent;
  border: 2rpx solid #00ff00;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.actions {
  margin-top: 48rpx;
}

/* Info Card */
.tips {
  margin-top: 48rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 32rpx 24rpx;
}

.tips::before {
  content: '> ';
  color: #00ff00;
  font-weight: bold;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #00ff00;
  margin-bottom: 16rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #00ff00;
  line-height: 44rpx;
}
