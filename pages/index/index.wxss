/* pages/index/index.wxss - Minimalist Dashboard */

.container {
  background: #ffffff;
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 64rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.header-title {
  display: flex;
  align-items: center;
}

.title-bar {
  width: 4rpx;
  height: 32rpx;
  background: #1a1a1a;
  margin-right: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}

.user-info-compact {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-small {
  width: 48rpx;
  height: 48rpx;
  border: none;
}

.username-small {
  font-size: 24rpx;
  color: #666666;
}

/* Info Card */
.info-card {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  margin-bottom: 64rpx;
  padding: 40rpx 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-title {
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 500;
}

.card-status {
  font-size: 20rpx;
  color: #1a1a1a;
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  font-weight: 500;
}

.card-status.inactive {
  color: #999999;
  background: #fafafa;
}

.card-content {
  padding: 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.info-label {
  font-size: 20rpx;
  color: #999999;
  font-weight: 400;
}

.info-value {
  font-size: 48rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* Stats Section */
.stats-section {
  margin-bottom: 64rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 500;
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* Stat Card */
.stat-card {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  padding: 40rpx 32rpx;
}

.stat-month {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.month-label {
  font-size: 18rpx;
  color: #999999;
  font-weight: 400;
}

.month-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.stat-details {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-label {
  font-size: 18rpx;
  color: #999999;
  font-weight: 400;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.stat-num.highlight {
  color: #1a1a1a;
  font-weight: 600;
}

.stat-num.positive {
  color: #1a1a1a;
}

.stat-num.negative {
  color: #666666;
}

/* Empty Stats */
.empty-stats {
  background: #fafafa;
  border: none;
  padding: 100rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
}

.empty-hint {
  font-size: 20rpx;
  color: #cccccc;
}

/* Actions */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 64rpx;
  padding-bottom: 40rpx;
}

.btn-primary,
.btn-secondary {
  background: #1a1a1a;
  color: #ffffff;
  border: none;
  padding: 28rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: opacity 0.2s ease;
}

.btn-primary:active {
  opacity: 0.7;
}

.btn-secondary {
  background: #ffffff;
  color: #1a1a1a;
  border: 1rpx solid #1a1a1a;
}

.btn-secondary:active {
  opacity: 0.7;
}

.btn-secondary[disabled] {
  background: #f5f5f5;
  color: #cccccc;
  border-color: #e5e5e5;
  opacity: 1;
}
