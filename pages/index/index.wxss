/* pages/index/index.wxss - TERMINAL.MAHJONG: User Dashboard */

/* User Profile Window */
.user-card {
  margin-top: 32rpx;
  background: rgba(0, 20, 10, 0.8);
  border: 2rpx solid #00ff41;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 20px rgba(0, 255, 65, 0.2);
}

/* Terminal window border */
.user-card::before {
  content: '╔══════════════ USER_PROFILE ══════════════╗';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  font-size: 16rpx;
  color: #00ff41;
  text-shadow: 0 0 5px #00ff41;
  font-family: 'Courier New', 'Courier', monospace;
  padding: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  border-bottom: 1rpx solid #00ff41;
  letter-spacing: 0.05em;
}

.user-info {
  display: flex;
  align-items: center;
  padding-left: 16rpx;
  padding-top: 48rpx;
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 0;
  margin-right: 32rpx;
  border: 4rpx solid #00ff41;
  box-shadow:
    0 0 20px rgba(0, 255, 65, 0.5),
    inset 0 0 10px rgba(0, 255, 65, 0.1);
  transition: all 0.2s ease;
  filter: contrast(1.2) brightness(1.1);
}

.avatar:active {
  transform: scale(0.95);
  box-shadow: 0 0 30px rgba(0, 255, 65, 0.7);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 38rpx;
  font-weight: 600;
  font-family: 'Courier New', 'Courier', monospace;
  color: #00ff41;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 0.08em;
  text-shadow: 0 0 10px #00ff41;
  text-transform: uppercase;
}

.username::before {
  content: '> ';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 20rpx;
  color: #00ff41;
  padding: 10rpx 20rpx;
  background: transparent;
  border: 2rpx solid #00ccff;
  font-weight: 600;
  font-family: 'Courier New', 'Courier', monospace;
  letter-spacing: 0.1em;
  text-shadow: 0 0 8px #00ccff;
  box-shadow: 0 0 8px rgba(0, 204, 255, 0.3);
  text-transform: uppercase;
}

.actions {
  margin-top: 48rpx;
}

/* System Information Panel */
.tips {
  margin-top: 48rpx;
  background: rgba(0, 20, 10, 0.8);
  border: 2rpx solid #00ccff;
  position: relative;
  box-shadow: 0 0 15px rgba(0, 204, 255, 0.2);
}

/* Terminal scan line effect */
.tips::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.03) 2px,
      rgba(0, 255, 65, 0.03) 4px
    );
  pointer-events: none;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  font-family: 'Courier New', 'Courier', monospace;
  color: #00ccff;
  margin-bottom: 20rpx;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-shadow: 0 0 10px #00ccff;
}

.tips-title::before {
  content: '[INFO] ';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.tips-content {
  font-size: 24rpx;
  color: #00ff41;
  line-height: 44rpx;
  letter-spacing: 0.02em;
  font-family: 'Courier New', 'Courier', monospace;
  text-shadow: 0 0 5px #00ff41;
}
