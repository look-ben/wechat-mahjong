/* pages/index/index.wxss - Minimalist: User Dashboard */

/* User Profile Card */
.user-card {
  margin-top: 48rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
  padding: 48rpx 0;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border: none;
  margin-right: 32rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: 500;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}

.stats {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #666666;
  padding: 0;
  background: transparent;
  border: none;
  font-weight: 400;
}

.actions {
  margin-top: 64rpx;
}

/* Info Card */
.tips {
  margin-top: 64rpx;
  background: #fafafa;
  border: none;
  padding: 32rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.tips-content {
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 44rpx;
}
