/* pages/index/index.wxss - Claude.ai 风格 */
.user-card {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 65rpx;
  margin-right: 32rpx;
  border: 4rpx solid rgba(217, 119, 87, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 38rpx;
  font-weight: 600;
  color: #2C1810;
  display: block;
  margin-bottom: 16rpx;
}

.stats {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  font-size: 28rpx;
  color: #9B8B7E;
  padding: 8rpx 16rpx;
  background-color: #FAF7F5;
  border-radius: 12rpx;
}

.actions {
  margin-top: 48rpx;
}

.tips {
  margin-top: 48rpx;
  background: linear-gradient(135deg, #FFF9F5 0%, #FFEEE5 100%);
  border-left: 4rpx solid #D97757;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #D97757;
  margin-bottom: 20rpx;
}

.tips-content {
  font-size: 28rpx;
  color: #6B5B4F;
  line-height: 52rpx;
}
