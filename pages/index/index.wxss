/* pages/index/index.wxss - Travel App 清新风格 */
.user-card {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border: 2rpx solid rgba(78, 205, 196, 0.15);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-right: 32rpx;
  border: 4rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 44rpx;
  font-weight: 600;
  color: #1A2B3C;
  display: block;
  margin-bottom: 16rpx;
}

.stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 26rpx;
  color: #44A8A0;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F9FB 100%);
  border-radius: 16rpx;
  font-weight: 500;
}

.actions {
  margin-top: 40rpx;
}

.tips {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #D4EEF5 100%);
  border-left: 5rpx solid #4ECDC4;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.1);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A2B3C;
  margin-bottom: 24rpx;
}

.tips-content {
  font-size: 28rpx;
  color: #5A7A85;
  line-height: 48rpx;
}
