/* pages/index/index.wxss - Ink & Jade: Home */

.user-card {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFAF8 100%);
  border: 3rpx solid rgba(45, 95, 78, 0.12);
  position: relative;
  overflow: hidden;
}

/* Decorative jade accent stripe */
.user-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #578772, #3D6455);
}

.user-info {
  display: flex;
  align-items: center;
  padding-left: 16rpx;
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  margin-right: 32rpx;
  border: 4rpx solid #578772;
  box-shadow:
    0 0 0 4rpx rgba(87, 135, 114, 0.15),
    0 8rpx 24rpx rgba(87, 135, 114, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.avatar:active {
  transform: scale(0.95);
}

.user-details {
  flex: 1;
}

.username {
  font-size: 42rpx;
  font-weight: 600;
  font-family: 'Noto Serif SC', serif;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 0.02em;
}

.stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #6B7566;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #F5F1E8 0%, #EBE7DE 100%);
  border-radius: 8rpx;
  font-weight: 500;
  border: 1rpx solid rgba(45, 95, 78, 0.08);
  letter-spacing: 0.02em;
}

.actions {
  margin-top: 48rpx;
}

.tips {
  margin-top: 48rpx;
  background: linear-gradient(135deg, #FAFAF8 0%, #F5F1E8 100%);
  border-left: 6rpx solid #578772;
  position: relative;
  box-shadow:
    0 2rpx 8rpx rgba(87, 135, 114, 0.08);
}

/* Traditional paper texture overlay */
.tips::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(87, 135, 114, 0.02) 2px,
      rgba(87, 135, 114, 0.02) 4px
    );
  pointer-events: none;
  border-radius: 16rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  font-family: 'Noto Serif SC', serif;
  color: #2D5F4E;
  margin-bottom: 20rpx;
  letter-spacing: 0.05em;
}

.tips-content {
  font-size: 26rpx;
  color: #4A5447;
  line-height: 48rpx;
  letter-spacing: 0.01em;
}
