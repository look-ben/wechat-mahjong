/* pages/game/game.wxss - Travel App 清新风格 */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A2B3C;
  margin-bottom: 30rpx;
  letter-spacing: 0.5rpx;
}

/* 玩家总分 */
.players-summary {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #FFFFFF 100%);
  border: 2rpx solid rgba(78, 205, 196, 0.1);
}

.players-scroll {
  white-space: nowrap;
  padding: 24rpx 0;
}

.player-item {
  display: inline-block;
  vertical-align: top;
  text-align: center;
  margin-right: 40rpx;
  min-width: 120rpx;
  transition: transform 0.3s ease;
}

.player-item:active {
  transform: scale(0.95);
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  display: block;
  margin: 0 auto 16rpx;
  border: 4rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.player-name {
  display: block;
  font-size: 24rpx;
  color: #7A9CA5;
  margin-bottom: 8rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.add-player {
  width: 120rpx;
}

.add-icon {
  width: 120rpx;
  height: 120rpx;
  border: 3rpx dashed #4ECDC4;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 60rpx;
  color: #4ECDC4;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8F4F8 100%);
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.1);
  transition: all 0.3s ease;
}

.add-icon:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #E8F4F8 0%, #D4EEF5 100%);
}

.add-text {
  font-size: 24rpx;
  color: #4ECDC4;
  font-weight: 500;
}

/* 计分记录 */
.rounds-section {
  margin-top: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #7A9CA5;
  font-size: 28rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F9FB 100%);
  border-radius: 20rpx;
  margin: 20rpx 0;
}

.rounds-list {
  max-height: 600rpx;
}

.round-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(78, 205, 196, 0.15);
  font-weight: 600;
  color: #5A7A85;
  font-size: 24rpx;
  background: linear-gradient(to bottom, #FFFFFF 0%, #F8FCFD 100%);
  position: sticky;
  top: 0;
  z-index: 10;
}

.round-num-header {
  width: 160rpx;
  flex-shrink: 0;
}

.round-score-header {
  flex: 1;
  text-align: center;
}

.header-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.2);
}

.round-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.08);
  transition: background-color 0.2s ease;
}

.round-item:active {
  background-color: #F8FCFD;
}

.round-num {
  width: 160rpx;
  flex-shrink: 0;
}

.round-num .num {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2B3C;
  margin-bottom: 8rpx;
}

.round-num .time {
  display: block;
  font-size: 20rpx;
  color: #7A9CA5;
}

.round-score {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

/* 操作按钮 */
.actions {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin: 16rpx 0;
}

.half {
  flex: 1;
  margin: 0;
}

/* 二维码弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 43, 60, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.modal-content {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  width: 600rpx;
  box-shadow: 0 16rpx 48rpx rgba(78, 205, 196, 0.2);
  border: 2rpx solid rgba(78, 205, 196, 0.1);
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1A2B3C;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border: 3rpx solid rgba(78, 205, 196, 0.2);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.modal-tip {
  text-align: center;
  color: #7A9CA5;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  line-height: 44rpx;
}

/* 玩家菜单 */
.player-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 43, 60, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.menu-content {
  background: linear-gradient(to top, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  width: 100%;
  box-shadow: 0 -8rpx 32rpx rgba(78, 205, 196, 0.15);
}

.menu-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
  color: #1A2B3C;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.1);
  font-size: 32rpx;
  color: #1A2B3C;
  border-radius: 16rpx;
  transition: background-color 0.2s ease;
}

.menu-item:active {
  background-color: #E8F4F8;
}

.menu-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  margin-right: 24rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.1);
}
