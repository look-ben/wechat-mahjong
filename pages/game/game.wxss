/* pages/game/game.wxss - AI Workflows: Active Session */

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  color: #ffffff;
  margin-bottom: 28rpx;
  letter-spacing: -0.02em;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 24rpx;
  background: linear-gradient(180deg, #8b5cf6, #6366f1);
  border-radius: 2rpx;
}

/* Connected Users Display */
.players-summary {
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.players-scroll {
  white-space: nowrap;
  padding: 32rpx 24rpx;
}

.player-item {
  display: inline-block;
  vertical-align: top;
  text-align: center;
  margin-right: 32rpx;
  min-width: 120rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.player-item:active {
  transform: translateY(-4rpx);
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: block;
  margin: 0 auto 16rpx;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow:
    0 8rpx 24rpx rgba(139, 92, 246, 0.2),
    0 0 0 4rpx rgba(139, 92, 246, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.player-item:active .player-avatar {
  transform: scale(0.95);
}

.player-name {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 10rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.player-score {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

/* Add Player Interface */
.add-player {
  width: 120rpx;
}

.add-icon {
  width: 120rpx;
  height: 120rpx;
  border: 2px dashed rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 52rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.03);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-icon:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(139, 92, 246, 0.5);
}

.add-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* Rounds Section */
.rounds-section {
  margin-top: 32rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin: 20rpx 0;
}

.rounds-list {
  max-height: 600rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.round-header {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  background: rgba(0, 0, 0, 0.3);
  position: sticky;
  top: 0;
  z-index: 10;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.round-num-header {
  width: 160rpx;
  flex-shrink: 0;
}

.round-score-header {
  flex: 1;
  text-align: center;
}

.header-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(139, 92, 246, 0.3);
}

.round-item {
  display: flex;
  align-items: center;
  padding: 28rpx 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
  background: rgba(0, 0, 0, 0.1);
}

.round-item:active {
  background: rgba(139, 92, 246, 0.1);
}

.round-num {
  width: 160rpx;
  flex-shrink: 0;
}

.round-num .num {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: -0.02em;
}

.round-num .time {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
}

.round-score {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

/* Actions */
.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

/* QR Code Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(12rpx);
}

.modal-content {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  width: 600rpx;
  box-shadow:
    0 16rpx 64rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: #ffffff;
  letter-spacing: -0.02em;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
  position: relative;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(139, 92, 246, 0.3),
    0 0 0 8rpx rgba(139, 92, 246, 0.1);
}

.modal-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-bottom: 40rpx;
  line-height: 40rpx;
}

/* Player Selection Menu */
.player-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  backdrop-filter: blur(12rpx);
}

.menu-content {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  width: 100%;
  box-shadow: 0 -16rpx 64rpx rgba(0, 0, 0, 0.4);
  position: relative;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: #ffffff;
  letter-spacing: -0.02em;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.menu-item:active {
  background: rgba(139, 92, 246, 0.2);
  transform: scale(0.98);
}

.menu-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}
