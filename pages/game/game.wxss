/* pages/game/game.wxss - Minimalist: Active Session */

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 32rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* Connected Users Display */
.players-summary {
  margin-top: 32rpx;
  background: #ffffff;
  border: none;
  border-bottom: 1rpx solid #e5e5e5;
  padding: 40rpx 0;
}

.players-scroll {
  white-space: nowrap;
}

.player-item {
  display: inline-block;
  vertical-align: top;
  text-align: center;
  margin-right: 48rpx;
  min-width: 100rpx;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border: none;
  display: block;
  margin: 0 auto 20rpx;
}

.player-name {
  display: block;
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 12rpx;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* Add Player Interface */
.add-player {
  width: 100rpx;
}

.add-icon {
  width: 100rpx;
  height: 100rpx;
  border: 1rpx dashed #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  font-size: 48rpx;
  color: #cccccc;
  background: transparent;
}

.add-text {
  font-size: 22rpx;
  color: #999999;
}

/* Rounds Section */
.rounds-section {
  margin-top: 48rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 26rpx;
  background: transparent;
  border: none;
  margin: 20rpx 0;
}

.rounds-list {
  max-height: 600rpx;
  background: #ffffff;
  border: none;
  overflow: hidden;
}

.round-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
  font-weight: 500;
  color: #666666;
  font-size: 20rpx;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.round-num-header {
  width: 160rpx;
  flex-shrink: 0;
}

.round-score-header {
  flex: 1;
  text-align: center;
}

.header-avatar {
  width: 48rpx;
  height: 48rpx;
  border: none;
}

.round-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  background: #ffffff;
}

.round-num {
  width: 160rpx;
  flex-shrink: 0;
}

.round-num .num {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.round-num .time {
  display: block;
  font-size: 18rpx;
  color: #999999;
}

.round-score {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* Actions */
.actions {
  margin-top: 64rpx;
  padding-bottom: 40rpx;
}

/* QR Code Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  padding: 60rpx 40rpx;
  width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 48rpx;
  color: #1a1a1a;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border: 1rpx solid #e5e5e5;
}

.modal-tip {
  text-align: center;
  color: #666666;
  font-size: 24rpx;
  margin-bottom: 40rpx;
  line-height: 40rpx;
}

/* Player Selection Menu */
.player-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.menu-content {
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  padding: 40rpx 32rpx;
  width: 100%;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 32rpx;
  color: #1a1a1a;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 0;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 24rpx;
  border: none;
}
