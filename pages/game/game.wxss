/* pages/game/game.wxss - Hugo Shell Retro: Active Session */

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
  color: #00ff00;
  margin-bottom: 28rpx;
  position: relative;
}

.section-title::before {
  content: '$ ';
  color: #00ff00;
}

/* Connected Users Display */
.players-summary {
  margin-top: 24rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 32rpx 24rpx;
}

.players-scroll {
  white-space: nowrap;
}

.player-item {
  display: inline-block;
  vertical-align: top;
  text-align: center;
  margin-right: 32rpx;
  min-width: 120rpx;
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx solid #00ff00;
  display: block;
  margin: 0 auto 16rpx;
}

.player-name {
  display: block;
  font-size: 22rpx;
  color: #00ff00;
  margin-bottom: 10rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #00ff00;
}

/* Add Player Interface */
.add-player {
  width: 120rpx;
}

.add-icon {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #00ff00;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 52rpx;
  color: #00ff00;
  background: transparent;
}

.add-text {
  font-size: 22rpx;
  color: #00ff00;
  text-decoration: underline;
}

/* Rounds Section */
.rounds-section {
  margin-top: 32rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #008800;
  font-size: 26rpx;
  background: #000000;
  border: 2rpx dashed #00ff00;
  margin: 20rpx 0;
}

.empty-tip::before {
  content: '[WAITING...]\n';
  color: #00ff00;
  display: block;
  margin-bottom: 20rpx;
}

.rounds-list {
  max-height: 600rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  overflow: hidden;
}

.round-header {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 2rpx solid #00ff00;
  font-weight: bold;
  color: #00ff00;
  font-size: 20rpx;
  background: #000000;
  position: sticky;
  top: 0;
  z-index: 10;
}

.round-num-header {
  width: 160rpx;
  flex-shrink: 0;
}

.round-num-header::before {
  content: '# ';
}

.round-score-header {
  flex: 1;
  text-align: center;
}

.header-avatar {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #00ff00;
}

.round-item {
  display: flex;
  align-items: center;
  padding: 28rpx 20rpx;
  border-bottom: 1rpx solid #00ff00;
  background: #000000;
}

.round-num {
  width: 160rpx;
  flex-shrink: 0;
}

.round-num .num {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #00ff00;
  margin-bottom: 8rpx;
}

.round-num .num::before {
  content: '[';
}

.round-num .num::after {
  content: ']';
}

.round-num .time {
  display: block;
  font-size: 18rpx;
  color: #008800;
}

.round-score {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #00ff00;
}

/* Actions */
.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

/* QR Code Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 60rpx 40rpx;
  width: 600rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #00ff00;
}

.modal-title::before {
  content: '> ';
}

.qrcode-container {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border: 2rpx solid #00ff00;
}

.modal-tip {
  text-align: center;
  color: #00ff00;
  font-size: 24rpx;
  margin-bottom: 40rpx;
  line-height: 40rpx;
}

/* Player Selection Menu */
.player-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.menu-content {
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 40rpx;
  width: 100%;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 32rpx;
  color: #00ff00;
}

.menu-title::before {
  content: '$ ';
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #00ff00;
  margin-bottom: 12rpx;
  background: transparent;
  border: none;
  text-decoration: underline;
}

.menu-item::before {
  content: '> ';
  text-decoration: none;
  margin-right: 12rpx;
}

.menu-avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 24rpx;
  border: 2rpx solid #00ff00;
}
