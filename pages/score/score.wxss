/* pages/score/score.wxss - Ink & Jade: Score Input */

.title {
  font-size: 46rpx;
  font-weight: 600;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", serif;
  text-align: center;
  color: #2D5F4E;
  margin-bottom: 24rpx;
  letter-spacing: 0.05em;
}

.tip {
  text-align: center;
  color: #6B7566;
  font-size: 26rpx;
  margin-bottom: 48rpx;
  line-height: 44rpx;
  letter-spacing: 0.01em;
}

.score-list {
  margin: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFAF8 100%);
  border-radius: 16rpx;
  padding: 24rpx 0;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.06),
    0 12rpx 32rpx rgba(87, 135, 114, 0.1);
  border: 3rpx solid rgba(45, 95, 78, 0.12);
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid rgba(87, 135, 114, 0.1);
  transition: background-color 0.2s ease;
}

.score-item:last-child {
  border-bottom: none;
}

.score-item:active {
  background: linear-gradient(135deg, #FAFAF8 0%, #F5F1E8 100%);
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  border: 4rpx solid #578772;
  box-shadow:
    0 0 0 3rpx rgba(87, 135, 114, 0.12),
    0 6rpx 20rpx rgba(87, 135, 114, 0.15);
}

.name {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 3rpx solid #578772;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", monospace;
  text-align: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFAF8 100%);
  color: #1A1A1A;
  box-shadow: inset 0 2rpx 4rpx rgba(87, 135, 114, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.score-input:focus {
  border-color: #2D5F4E;
  box-shadow:
    inset 0 2rpx 4rpx rgba(87, 135, 114, 0.08),
    0 0 0 4rpx rgba(87, 135, 114, 0.15);
  background: #FFFFFF;
}

.score-input[disabled] {
  background: linear-gradient(135deg, #F5F1E8 0%, #EBE7DE 100%);
  border-color: rgba(87, 135, 114, 0.2);
  color: #9B9B8F;
  box-shadow: none;
}

.total-tip {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", serif;
  margin: 48rpx 0;
  padding: 32rpx;
  background: linear-gradient(135deg, #FAFAF8 0%, #F5F1E8 100%);
  border-radius: 16rpx;
  color: #578772;
  border: 3rpx solid rgba(87, 135, 114, 0.2);
  box-shadow:
    0 4rpx 16rpx rgba(87, 135, 114, 0.12);
  letter-spacing: 0.02em;
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
