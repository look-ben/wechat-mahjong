/* pages/score/score.wxss - TERMINAL.MAHJONG: Data Input */

.title {
  font-size: 42rpx;
  font-weight: 600;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
  text-align: center;
  color: #00ff41;
  margin-bottom: 24rpx;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-shadow: 0 0 15px #00ff41;
}

.title::before {
  content: '>>> ';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.title::after {
  content: ' <<<';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.tip {
  text-align: center;
  color: #00ccff;
  font-size: 24rpx;
  margin-bottom: 48rpx;
  line-height: 44rpx;
  letter-spacing: 0.05em;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
  text-shadow: 0 0 8px #00ccff;
}

.tip::before {
  content: '[';
  color: #ff0080;
  margin-right: 4rpx;
}

.tip::after {
  content: ']';
  color: #ff0080;
  margin-left: 4rpx;
}

/* Score Input Terminal */
.score-list {
  margin: 48rpx 0;
  background: rgba(0, 20, 10, 0.8);
  padding: 24rpx 0;
  box-shadow: 0 0 20px rgba(0, 255, 65, 0.2);
  border: 2rpx solid #00ff41;
  position: relative;
}

.score-list::before {
  content: '╔═══════════════ INPUT_SCORES ═══════════════╗';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  font-size: 14rpx;
  color: #00ff41;
  text-shadow: 0 0 5px #00ff41;
  overflow: hidden;
  white-space: nowrap;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid rgba(0, 255, 65, 0.2);
  transition: all 0.2s ease;
}

.score-item:last-child {
  border-bottom: none;
}

.score-item:active {
  background: rgba(0, 255, 65, 0.05);
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.player-info::before {
  content: '>';
  color: #ff0080;
  margin-right: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 0 10px #ff0080;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 0;
  margin-right: 24rpx;
  border: 3rpx solid #00ff41;
  box-shadow: 0 0 20px rgba(0, 255, 65, 0.4);
  filter: contrast(1.2) brightness(1.1);
}

.name {
  font-size: 28rpx;
  color: #00ff41;
  font-weight: 600;
  letter-spacing: 0.08em;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
  text-shadow: 0 0 8px #00ff41;
  text-transform: uppercase;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 3rpx solid #00ccff;
  border-radius: 0;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #00ff41;
  box-shadow:
    inset 0 0 10px rgba(0, 255, 65, 0.1),
    0 0 15px rgba(0, 204, 255, 0.3);
  transition: all 0.2s ease;
  text-shadow: 0 0 10px #00ff41;
}

.score-input:focus {
  border-color: #00ff41;
  box-shadow:
    inset 0 0 15px rgba(0, 255, 65, 0.2),
    0 0 25px rgba(0, 255, 65, 0.5);
  background: rgba(0, 0, 0, 0.8);
}

.score-input[disabled] {
  background: rgba(0, 20, 10, 0.4);
  border-color: #1a3a1a;
  color: #00aa33;
  box-shadow: none;
  text-shadow: 0 0 5px #00aa33;
}

/* Validation Display */
.total-tip {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
  margin: 48rpx 0;
  padding: 32rpx;
  background: rgba(0, 20, 10, 0.8);
  border: 3rpx solid #00ccff;
  color: #00ccff;
  box-shadow: 0 0 20px rgba(0, 204, 255, 0.3);
  letter-spacing: 0.08em;
  text-shadow: 0 0 10px #00ccff;
  text-transform: uppercase;
}

.total-tip::before {
  content: '[VALIDATION] ';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
