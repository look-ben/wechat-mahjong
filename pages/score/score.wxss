/* pages/score/score.wxss - Minimalist: Score Input */

.title {
  font-size: 36rpx;
  font-weight: 500;
  text-align: center;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

.tip {
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  margin-bottom: 64rpx;
  line-height: 40rpx;
}

/* Score Input Card */
.score-list {
  margin: 64rpx 0;
  background: #ffffff;
  border: none;
  padding: 0;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.score-item:last-child {
  border-bottom: none;
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
  border: none;
}

.name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
}

.score-input {
  width: 160rpx;
  height: 80rpx;
  border: none;
  border-bottom: 1rpx solid #e5e5e5;
  padding: 0;
  font-size: 36rpx;
  font-weight: 500;
  text-align: center;
  background: #ffffff;
  color: #1a1a1a;
}

.score-input:focus {
  outline: none;
  border-bottom-color: #1a1a1a;
}

.score-input[disabled] {
  background: #ffffff;
  border-bottom-color: #f5f5f5;
  color: #cccccc;
}

/* Validation Display */
.total-tip {
  text-align: center;
  font-size: 28rpx;
  font-weight: 400;
  margin: 64rpx 0;
  padding: 32rpx;
  background: #fafafa;
  border: none;
  color: #666666;
}

.actions {
  margin-top: 80rpx;
  padding-bottom: 40rpx;
}
