/* pages/score/score.wxss - Claude.ai 风格 */
.title {
  font-size: 48rpx;
  font-weight: 600;
  text-align: center;
  color: #2C1810;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.tip {
  text-align: center;
  color: #9B8B7E;
  font-size: 28rpx;
  margin-bottom: 48rpx;
  line-height: 44rpx;
}

.score-list {
  margin: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 36rpx;
  border-bottom: 1rpx solid rgba(217, 119, 87, 0.08);
  transition: background-color 0.2s ease;
}

.score-item:last-child {
  border-bottom: none;
}

.score-item:active {
  background-color: #FAF7F5;
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 45rpx;
  margin-right: 24rpx;
  border: 3rpx solid rgba(217, 119, 87, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.name {
  font-size: 32rpx;
  color: #2C1810;
  font-weight: 500;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 2rpx solid rgba(217, 119, 87, 0.2);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F5 100%);
  color: #2C1810;
  transition: all 0.3s ease;
}

.score-input:focus {
  border-color: #D97757;
  box-shadow: 0 0 0 4rpx rgba(217, 119, 87, 0.1);
}

.score-input[disabled] {
  background: linear-gradient(135deg, #FAF7F5 0%, #F5EDE6 100%);
  border-color: rgba(217, 119, 87, 0.1);
  color: #9B8B7E;
}

.total-tip {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin: 48rpx 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFF9F5 0%, #FFEEE5 100%);
  border-radius: 16rpx;
  color: #D97757;
  border: 2rpx solid rgba(217, 119, 87, 0.15);
  box-shadow: 0 2rpx 12rpx rgba(217, 119, 87, 0.1);
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
