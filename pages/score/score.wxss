/* pages/score/score.wxss - AI Workflows: Score Input */

.title {
  font-size: 42rpx;
  font-weight: 700;
  text-align: center;
  color: #ffffff;
  margin-bottom: 24rpx;
  letter-spacing: -0.02em;
}

.tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-bottom: 48rpx;
  line-height: 40rpx;
}

/* Score Input Card */
.score-list {
  margin: 48rpx 0;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 24rpx 0;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
}

.score-item:last-child {
  border-bottom: none;
}

.score-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow:
    0 8rpx 24rpx rgba(139, 92, 246, 0.2),
    0 0 0 4rpx rgba(139, 92, 246, 0.1);
}

.name {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  background: rgba(0, 0, 0, 0.3);
  color: #ffffff;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.score-input:focus {
  border-color: #8b5cf6;
  box-shadow:
    inset 0 2rpx 8rpx rgba(0, 0, 0, 0.2),
    0 0 0 4rpx rgba(139, 92, 246, 0.2);
  background: rgba(0, 0, 0, 0.4);
}

.score-input[disabled] {
  background: rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
}

/* Validation Display */
.total-tip {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  margin: 48rpx 0;
  padding: 32rpx;
  background: rgba(139, 92, 246, 0.1);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 20rpx;
  color: #a78bfa;
  box-shadow:
    0 8rpx 24rpx rgba(139, 92, 246, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
