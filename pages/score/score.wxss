/* pages/score/score.wxss */
.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 20rpx;
}

.tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.score-list {
  margin: 40rpx 0;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.player-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
}

.score-input {
  width: 200rpx;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
}

.total-tip {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin: 40rpx 0;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.actions {
  margin-top: 60rpx;
}
