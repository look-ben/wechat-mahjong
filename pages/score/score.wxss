/* pages/score/score.wxss - Hugo Shell Retro: Score Input */

.title {
  font-size: 42rpx;
  font-weight: bold;
  text-align: center;
  color: #00ff00;
  margin-bottom: 24rpx;
}

.title::before {
  content: '# ';
}

.tip {
  text-align: center;
  color: #00ff00;
  font-size: 24rpx;
  margin-bottom: 48rpx;
  line-height: 40rpx;
}

/* Score Input Card */
.score-list {
  margin: 48rpx 0;
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 24rpx 0;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #00ff00;
}

.score-item:last-child {
  border-bottom: none;
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
  border: 2rpx solid #00ff00;
}

.name {
  font-size: 28rpx;
  color: #00ff00;
  font-weight: bold;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 2rpx solid #00ff00;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  background: #000000;
  color: #00ff00;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.score-input:focus {
  outline: none;
  border-color: #00dd00;
}

.score-input[disabled] {
  background: #000000;
  border-color: #008800;
  color: #008800;
}

/* Validation Display */
.total-tip {
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  margin: 48rpx 0;
  padding: 32rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  color: #00ff00;
}

.total-tip::before {
  content: '[SUM] ';
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
