/* pages/score/score.wxss - Travel App 清新风格 */
.title {
  font-size: 48rpx;
  font-weight: 600;
  text-align: center;
  color: #1A2B3C;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.tip {
  text-align: center;
  color: #7A9CA5;
  font-size: 28rpx;
  margin-bottom: 48rpx;
  line-height: 44rpx;
}

.score-list {
  margin: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.1);
  border: 2rpx solid rgba(78, 205, 196, 0.1);
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 36rpx;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.1);
  transition: background-color 0.2s ease;
}

.score-item:last-child {
  border-bottom: none;
}

.score-item:active {
  background-color: #E8F4F8;
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.name {
  font-size: 32rpx;
  color: #1A2B3C;
  font-weight: 500;
}

.score-input {
  width: 200rpx;
  height: 88rpx;
  border: 3rpx solid rgba(78, 205, 196, 0.3);
  border-radius: 24rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8F4F8 100%);
  color: #1A2B3C;
  transition: all 0.3s ease;
}

.score-input:focus {
  border-color: #4ECDC4;
  box-shadow: 0 0 0 6rpx rgba(78, 205, 196, 0.15);
  background: white;
}

.score-input[disabled] {
  background: linear-gradient(135deg, #E8F4F8 0%, #D4EEF5 100%);
  border-color: rgba(78, 205, 196, 0.15);
  color: #7A9CA5;
}

.total-tip {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin: 48rpx 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #D4EEF5 100%);
  border-radius: 24rpx;
  color: #4ECDC4;
  border: 3rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.15);
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
