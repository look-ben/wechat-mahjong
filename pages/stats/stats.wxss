/* pages/stats/stats.wxss - Claude.ai 风格 */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0;
  border-bottom: 2rpx solid rgba(217, 119, 87, 0.1);
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
  border-radius: 20rpx 20rpx 0 0;
}

.selector-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #D97757;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.selector-btn:active {
  background-color: #FAF7F5;
  transform: scale(0.95);
}

.month-display {
  font-size: 40rpx;
  font-weight: 600;
  color: #2C1810;
  min-width: 240rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
  border-radius: 0 0 20rpx 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #FFF9F5 0%, #FFFFFF 100%);
  border-radius: 16rpx;
  min-width: 160rpx;
  box-shadow: 0 2rpx 12rpx rgba(217, 119, 87, 0.08);
}

.stat-label {
  font-size: 24rpx;
  color: #9B8B7E;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 600;
  color: #D97757;
  margin-bottom: 8rpx;
}

.stat-unit {
  font-size: 24rpx;
  color: #9B8B7E;
}

.games-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 30rpx;
  letter-spacing: 0.5rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #9B8B7E;
  font-size: 28rpx;
  background: linear-gradient(135deg, #FAF7F5 0%, #F5EDE6 100%);
  border-radius: 16rpx;
  margin: 20rpx 0;
}

.game-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.game-item {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(217, 119, 87, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.game-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(217, 119, 87, 0.08);
}

.game-date {
  font-size: 26rpx;
  color: #9B8B7E;
  font-weight: 500;
}

.game-result {
  font-size: 40rpx;
  font-weight: 600;
}

.game-players {
  display: flex;
  align-items: center;
}

.player-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  margin-right: 12rpx;
  border: 2rpx solid rgba(217, 119, 87, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.rounds-count {
  font-size: 24rpx;
  color: #9B8B7E;
  margin-left: 20rpx;
  padding: 6rpx 16rpx;
  background-color: #FAF7F5;
  border-radius: 12rpx;
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
