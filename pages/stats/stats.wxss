/* pages/stats/stats.wxss - Minimalist: Statistics */

/* Month Navigation */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background: #ffffff;
  border: none;
  border-bottom: 1rpx solid #e5e5e5;
  margin-bottom: 48rpx;
}

.selector-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1a1a1a;
  background: transparent;
}

.month-display {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  min-width: 240rpx;
  text-align: center;
}

/* Stats Grid */
.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 0;
  background: #ffffff;
  border: none;
  border-bottom: 1rpx solid #e5e5e5;
  margin-bottom: 48rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  background: transparent;
  border: none;
  min-width: 120rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 16rpx;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stat-unit {
  font-size: 20rpx;
  color: #cccccc;
  font-weight: 400;
}

/* Game Log Section */
.games-section {
  margin-top: 64rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 32rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #cccccc;
  font-size: 26rpx;
  background: transparent;
  border: none;
  margin: 20rpx 0;
}

.game-list {
  max-height: 600rpx;
  overflow-y: auto;
}

/* Game Log Entries */
.game-item {
  padding: 40rpx 0;
  background: #ffffff;
  border: none;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 0;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 0;
  border: none;
}

.game-date {
  font-size: 22rpx;
  color: #999999;
}

.game-result {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.game-players {
  display: flex;
  align-items: center;
}

.player-avatar-small {
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
  border: none;
}

.rounds-count {
  font-size: 20rpx;
  color: #999999;
  margin-left: 20rpx;
  padding: 0;
  background: transparent;
  border: none;
  font-weight: 400;
}

.actions {
  margin-top: 80rpx;
  padding-bottom: 40rpx;
}
