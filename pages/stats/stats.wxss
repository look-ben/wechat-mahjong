/* pages/stats/stats.wxss - Hugo Shell Retro: Statistics */

/* Month Navigation */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0;
  background: #000000;
  border: 2rpx solid #00ff00;
  margin-bottom: 24rpx;
}

.selector-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #00ff00;
  background: transparent;
  text-decoration: underline;
}

.month-display {
  font-size: 40rpx;
  font-weight: bold;
  color: #00ff00;
  min-width: 240rpx;
  text-align: center;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

/* Stats Grid */
.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 24rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  margin-bottom: 40rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  background: transparent;
  border: 2rpx solid #00ff00;
  min-width: 160rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #00ff00;
  margin-bottom: 16rpx;
  font-weight: bold;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.stat-label::after {
  content: ':';
}

.stat-value {
  font-size: 52rpx;
  font-weight: bold;
  color: #00ff00;
  margin-bottom: 8rpx;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.stat-unit {
  font-size: 20rpx;
  color: #008800;
}

/* Game Log Section */
.games-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #00ff00;
  margin-bottom: 30rpx;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.section-title::before {
  content: '$ tree ./games/\n├── ';
  display: block;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #008800;
  font-size: 26rpx;
  background: #000000;
  border: 2rpx dashed #00ff00;
  margin: 20rpx 0;
}

.empty-tip::before {
  content: '[NO DATA]\n';
  color: #00ff00;
  display: block;
  margin-bottom: 20rpx;
}

.game-list {
  max-height: 600rpx;
  overflow-y: auto;
}

/* Game Log Entries */
.game-item {
  padding: 32rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
  margin-bottom: 24rpx;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #00ff00;
}

.game-date {
  font-size: 22rpx;
  color: #00ff00;
}

.game-date::before {
  content: '└── ';
}

.game-result {
  font-size: 36rpx;
  font-weight: bold;
  color: #00ff00;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.game-players {
  display: flex;
  align-items: center;
}

.player-avatar-small {
  width: 56rpx;
  height: 56rpx;
  margin-right: 12rpx;
  border: 2rpx solid #00ff00;
}

.rounds-count {
  font-size: 20rpx;
  color: #00ff00;
  margin-left: 20rpx;
  padding: 8rpx 20rpx;
  background: transparent;
  border: 2rpx solid #00ff00;
  font-weight: bold;
}

.rounds-count::before {
  content: '[';
}

.rounds-count::after {
  content: ']';
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
