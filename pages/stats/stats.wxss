/* pages/stats/stats.wxss - AI Workflows: Statistics */

/* Month Navigation */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.selector-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.2s ease;
  border-radius: 16rpx;
}

.selector-btn:active {
  background: rgba(139, 92, 246, 0.2);
  transform: scale(0.9);
}

.month-display {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  min-width: 240rpx;
  text-align: center;
  letter-spacing: -0.02em;
}

/* Stats Grid */
.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin-bottom: 40rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 20rpx;
  min-width: 160rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: -0.02em;
}

.stat-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* Game Log Section */
.games-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 30rpx;
  letter-spacing: -0.02em;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 24rpx;
  background: linear-gradient(180deg, #8b5cf6, #6366f1);
  border-radius: 2rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin: 20rpx 0;
}

.game-list {
  max-height: 600rpx;
  overflow-y: auto;
}

/* Game Log Entries */
.game-item {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.game-item:active {
  transform: translateY(-2rpx);
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.game-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.game-result {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.game-players {
  display: flex;
  align-items: center;
}

.player-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.rounds-count {
  font-size: 20rpx;
  color: #a78bfa;
  margin-left: 20rpx;
  padding: 8rpx 20rpx;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 12rpx;
  font-weight: 600;
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
