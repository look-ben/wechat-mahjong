/* pages/stats/stats.wxss - Travel App 清新风格 */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0;
  border-bottom: 2rpx solid rgba(78, 205, 196, 0.15);
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 28rpx 28rpx 0 0;
}

.selector-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #4ECDC4;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.selector-btn:active {
  background-color: #E8F4F8;
  transform: scale(0.95);
}

.month-display {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A2B3C;
  min-width: 240rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 0 0 28rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.1);
  margin-bottom: 40rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.1);
  border-top: none;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  min-width: 160rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.1);
}

.stat-label {
  font-size: 24rpx;
  color: #7A9CA5;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 600;
  color: #4ECDC4;
  margin-bottom: 8rpx;
}

.stat-unit {
  font-size: 24rpx;
  color: #7A9CA5;
}

.games-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2B3C;
  margin-bottom: 30rpx;
  letter-spacing: 0.5rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #7A9CA5;
  font-size: 28rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F9FB 100%);
  border-radius: 20rpx;
  margin: 20rpx 0;
}

.game-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.game-item {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.08);
  transition: all 0.3s ease;
}

.game-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.1);
}

.game-date {
  font-size: 26rpx;
  color: #7A9CA5;
  font-weight: 500;
}

.game-result {
  font-size: 40rpx;
  font-weight: 600;
}

.game-players {
  display: flex;
  align-items: center;
}

.player-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  margin-right: 12rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.1);
}

.rounds-count {
  font-size: 24rpx;
  color: #7A9CA5;
  margin-left: 20rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F9FB 100%);
  border-radius: 12rpx;
}

.actions {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
