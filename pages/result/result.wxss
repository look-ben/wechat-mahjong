/* pages/result/result.wxss - AI Workflows: Final Scores */

.title {
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  color: #ffffff;
  margin-bottom: 60rpx;
  letter-spacing: -0.02em;
}

/* Leaderboard */
.ranking-list {
  margin: 48rpx 0;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 24rpx 0;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
  position: relative;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item:active {
  background: rgba(255, 255, 255, 0.03);
}

/* Modern rank badges */
.rank-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.2);
  letter-spacing: -0.02em;
}

.rank-badge.first {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-color: rgba(251, 191, 36, 0.5);
  color: #ffffff;
  box-shadow:
    0 8rpx 24rpx rgba(251, 191, 36, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.rank-badge.second {
  background: linear-gradient(135deg, #e5e7eb 0%, #9ca3af 100%);
  border-color: rgba(156, 163, 175, 0.5);
  color: #ffffff;
  box-shadow:
    0 8rpx 24rpx rgba(156, 163, 175, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.rank-badge.third {
  background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
  border-color: rgba(249, 115, 22, 0.5);
  color: #ffffff;
  box-shadow:
    0 8rpx 24rpx rgba(249, 115, 22, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  margin-right: 28rpx;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow:
    0 8rpx 24rpx rgba(139, 92, 246, 0.2),
    0 0 0 4rpx rgba(139, 92, 246, 0.1);
}

.player-detail {
  flex: 1;
}

.name {
  display: block;
  font-size: 30rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.rounds-info {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.score {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

/* Game Session Info */
.game-info {
  margin: 60rpx 0;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  font-size: 26rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.value {
  color: #ffffff;
  font-weight: 600;
}

.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}
