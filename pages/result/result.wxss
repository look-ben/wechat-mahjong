/* pages/result/result.wxss - Claude.ai 风格 */
.title {
  font-size: 56rpx;
  font-weight: 600;
  text-align: center;
  color: #2C1810;
  margin-bottom: 60rpx;
  letter-spacing: 0.5rpx;
}

.ranking-list {
  margin: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F5 100%);
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid rgba(217, 119, 87, 0.08);
  transition: background-color 0.2s ease;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item:active {
  background-color: #FAF7F5;
}

.rank-badge {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #D97757 0%, #C95B3C 100%);
  box-shadow: 0 4rpx 12rpx rgba(217, 119, 87, 0.3);
}

.rank-badge.first {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.4);
}

.rank-badge.second {
  background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%);
  box-shadow: 0 4rpx 16rpx rgba(192, 192, 192, 0.4);
}

.rank-badge.third {
  background: linear-gradient(135deg, #CD7F32 0%, #B8722D 100%);
  box-shadow: 0 4rpx 16rpx rgba(205, 127, 50, 0.4);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 28rpx;
  border: 3rpx solid rgba(217, 119, 87, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.player-detail {
  flex: 1;
}

.name {
  display: block;
  font-size: 34rpx;
  color: #2C1810;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.rounds-info {
  display: block;
  font-size: 24rpx;
  color: #9B8B7E;
}

.score {
  font-size: 44rpx;
  font-weight: 600;
}

.game-info {
  margin: 60rpx 0;
  padding: 36rpx;
  background: linear-gradient(135deg, #FFF9F5 0%, #FFEEE5 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(217, 119, 87, 0.1);
  box-shadow: 0 2rpx 16rpx rgba(217, 119, 87, 0.08);
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid rgba(217, 119, 87, 0.08);
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: #6B5B4F;
  font-weight: 500;
}

.value {
  color: #2C1810;
  font-weight: 600;
}

.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}
