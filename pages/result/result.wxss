/* pages/result/result.wxss - Travel App 清新风格 */
.title {
  font-size: 56rpx;
  font-weight: 600;
  text-align: center;
  color: #1A2B3C;
  margin-bottom: 60rpx;
  letter-spacing: 0.5rpx;
}

.ranking-list {
  margin: 48rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FCFD 100%);
  border-radius: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.1);
  border: 2rpx solid rgba(78, 205, 196, 0.1);
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.1);
  transition: background-color 0.2s ease;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item:active {
  background-color: #E8F4F8;
}

.rank-badge {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #44A8A0 100%);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.3);
}

.rank-badge.first {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.4);
}

.rank-badge.second {
  background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%);
  box-shadow: 0 8rpx 24rpx rgba(192, 192, 192, 0.4);
}

.rank-badge.third {
  background: linear-gradient(135deg, #CD7F32 0%, #B8722D 100%);
  box-shadow: 0 8rpx 24rpx rgba(205, 127, 50, 0.4);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 28rpx;
  border: 4rpx solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.15);
}

.player-detail {
  flex: 1;
}

.name {
  display: block;
  font-size: 34rpx;
  color: #1A2B3C;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.rounds-info {
  display: block;
  font-size: 24rpx;
  color: #7A9CA5;
}

.score {
  font-size: 44rpx;
  font-weight: 600;
}

.game-info {
  margin: 60rpx 0;
  padding: 36rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #D4EEF5 100%);
  border-radius: 28rpx;
  border: 3rpx solid rgba(78, 205, 196, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.1);
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.1);
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: #5A7A85;
  font-weight: 500;
}

.value {
  color: #1A2B3C;
  font-weight: 600;
}

.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}
