/* pages/result/result.wxss - Hugo Shell Retro: Final Scores */

.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  color: #00ff00;
  margin-bottom: 60rpx;
}

.title::before {
  content: '## ';
}

/* Leaderboard */
.ranking-list {
  margin: 48rpx 0;
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 24rpx 0;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #00ff00;
}

.ranking-item:last-child {
  border-bottom: none;
}

/* Rank badges - terminal style */
.rank-badge {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #00ff00;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 24rpx;
  background: transparent;
  border: 2rpx solid #00ff00;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
}

.rank-badge.first::before {
  content: '1';
}

.rank-badge.second::before {
  content: '2';
}

.rank-badge.third::before {
  content: '3';
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 28rpx;
  border: 2rpx solid #00ff00;
}

.player-detail {
  flex: 1;
}

.name {
  display: block;
  font-size: 30rpx;
  color: #00ff00;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.rounds-info {
  display: block;
  font-size: 20rpx;
  color: #008800;
}

.score {
  font-size: 44rpx;
  font-weight: bold;
  color: #00ff00;
}

/* Game Session Info */
.game-info {
  margin: 60rpx 0;
  padding: 40rpx;
  background: #000000;
  border: 2rpx solid #00ff00;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  font-size: 26rpx;
  border-bottom: 1rpx solid #00ff00;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: #00ff00;
}

.label::after {
  content: ':';
}

.value {
  color: #00ff00;
  font-weight: bold;
}

.actions {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}
