/* pages/result/result.wxss */
.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 60rpx;
}

.ranking-list {
  margin: 40rpx 0;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 45rpx;
  margin-right: 24rpx;
}

.player-detail {
  flex: 1;
}

.name {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.rounds-info {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.score {
  font-size: 40rpx;
  font-weight: bold;
}

.game-info {
  margin: 60rpx 0;
  padding: 30rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.label {
  color: #666;
}

.value {
  color: #333;
  font-weight: bold;
}

.actions {
  margin-top: 40rpx;
}
