/* app.wxss - Ink & Jade Design System */

/* Design Philosophy:
   East meets West - Traditional Chinese gaming aesthetics with contemporary refinement
   Jade greens, ink blacks, paper cream, with calligraphic influences
*/

page {
  /* Textured paper background with subtle noise */
  background: #F5F1E8;
  background-image:
    radial-gradient(at 40% 20%, rgba(163, 177, 138, 0.05) 0px, transparent 50%),
    radial-gradient(at 80% 80%, rgba(87, 135, 114, 0.03) 0px, transparent 50%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  min-height: 100vh;
  color: #1A1A1A;
}

/* Typography System - 使用系统中文字体 */
.title-display {
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", serif;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.title-accent {
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", serif;
  font-weight: 600;
  color: #2D5F4E;
}

.body-text {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  letter-spacing: -0.01em;
}

.container {
  padding: 28rpx 32rpx 48rpx;
  box-sizing: border-box;
  position: relative;
}

/* Decorative corner accent - inspired by Chinese seals */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  right: 0;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #578772 0%, #3D6455 100%);
  opacity: 0.08;
  clip-path: polygon(100% 0, 100% 100%, 0 0);
  z-index: 0;
}

/* Primary Button - Jade Stone Effect */
.btn-primary {
  position: relative;
  background: linear-gradient(135deg, #578772 0%, #3D6455 100%);
  color: #F5F1E8;
  border: none;
  border-radius: 12rpx;
  padding: 36rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'IBM Plex Sans', sans-serif;
  margin: 20rpx 0;
  box-shadow:
    0 2rpx 0 0 rgba(29, 47, 39, 0.8),
    0 8rpx 24rpx rgba(61, 100, 85, 0.25),
    inset 0 1rpx 0 0 rgba(255, 255, 255, 0.1);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

/* Subtle jade shimmer effect */
.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  transition: left 0.5s;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow:
    0 0rpx 0 0 rgba(29, 47, 39, 0.8),
    0 4rpx 12rpx rgba(61, 100, 85, 0.2),
    inset 0 1rpx 0 0 rgba(255, 255, 255, 0.1);
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #9B9B9B 0%, #7A7A7A 100%);
  color: #D4D4D4;
  box-shadow:
    0 2rpx 0 0 rgba(90, 90, 90, 0.5),
    0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  opacity: 0.5;
}

/* Secondary Button - Ink Outline */
.btn-secondary {
  background-color: #F5F1E8;
  color: #2D5F4E;
  border: 3rpx solid #2D5F4E;
  border-radius: 12rpx;
  padding: 34rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  font-family: 'IBM Plex Sans', sans-serif;
  margin: 20rpx 0;
  box-shadow:
    4rpx 4rpx 0 0 rgba(45, 95, 78, 0.15);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.btn-secondary:active {
  transform: translate(2rpx, 2rpx);
  box-shadow:
    2rpx 2rpx 0 0 rgba(45, 95, 78, 0.15);
}

.btn-secondary[disabled] {
  background-color: #E8E4DB;
  color: #9B9B9B;
  border-color: #C4C4C4;
  box-shadow: 2rpx 2rpx 0 0 rgba(0, 0, 0, 0.05);
  opacity: 0.6;
}

/* Danger Button - Cinnabar Red */
.btn-danger {
  background: linear-gradient(135deg, #C44536 0%, #A63929 100%);
  color: #F5F1E8;
  border: none;
  border-radius: 12rpx;
  padding: 36rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  font-family: 'IBM Plex Sans', sans-serif;
  margin: 20rpx 0;
  box-shadow:
    0 2rpx 0 0 rgba(120, 40, 30, 0.8),
    0 8rpx 24rpx rgba(196, 69, 54, 0.3);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-danger:active {
  transform: translateY(2rpx);
  box-shadow:
    0 0rpx 0 0 rgba(120, 40, 30, 0.8),
    0 4rpx 12rpx rgba(196, 69, 54, 0.25);
}

/* Button Group Layout */
.action-row {
  display: flex;
  gap: 24rpx;
  margin: 20rpx 0;
}

.action-row .half {
  flex: 1;
  margin: 0;
}

/* Card System - Paper with Ink Borders */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 44rpx 40rpx;
  margin: 28rpx 0;
  box-shadow:
    0 1rpx 3rpx rgba(0, 0, 0, 0.06),
    0 8rpx 32rpx rgba(87, 135, 114, 0.08);
  border: 2rpx solid rgba(45, 95, 78, 0.1);
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Decorative ink dot accent */
.card::after {
  content: '';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 8rpx;
  height: 8rpx;
  background: #578772;
  border-radius: 50%;
  opacity: 0.3;
}

.card:active {
  transform: translateY(-2rpx);
  box-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.08),
    0 12rpx 40rpx rgba(87, 135, 114, 0.12);
}

/* Typography Utilities */
.text-center {
  text-align: center;
}

.text-muted {
  color: #6B7566;
  font-size: 26rpx;
  font-weight: 400;
}

.text-accent {
  color: #578772;
  font-weight: 600;
}

/* Score Colors - Harmonized with palette */
.score-positive {
  color: #578772;
  font-weight: 600;
}

.score-negative {
  color: #C44536;
  font-weight: 600;
}

.score-neutral {
  color: #6B7566;
  font-weight: 500;
}

/* Divider - Brush Stroke Style */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(45, 95, 78, 0.2), transparent);
  margin: 32rpx 0;
}

/* Badge - Traditional Seal Style */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  background: #2D5F4E;
  color: #F5F1E8;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 6rpx;
  letter-spacing: 0.05em;
  box-shadow:
    0 2rpx 0 0 rgba(29, 47, 39, 0.5),
    0 4rpx 8rpx rgba(45, 95, 78, 0.2);
}

/* Loading Animation - Organic Pulse */
@keyframes pulse-jade {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(0.95);
  }
}

.loading {
  animation: pulse-jade 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}
