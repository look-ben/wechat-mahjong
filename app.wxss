/* app.wxss - TERMINAL.MAHJONG - Cyberpunk Hacker Aesthetic */

/* Design Philosophy:
   Retro CRT terminal meets cyberpunk underground
   Phosphor green on black, monospace everything, scan lines, glitch effects
   You're not using an app - you're operating a terminal
*/

page {
  background: #0a0e0f;
  font-family: 'Courier New', 'Courier', monospace;
  min-height: 100vh;
  color: #00ff41;
  position: relative;
  overflow-x: hidden;
  -webkit-font-smoothing: none;
  -moz-osx-font-smoothing: grayscale;
  font-smoothing: none;
}

/* CRT Scan Lines Effect */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    0deg,
    rgba(0, 0, 0, 0.15),
    rgba(0, 0, 0, 0.15) 1px,
    transparent 1px,
    transparent 2px
  );
  pointer-events: none;
  z-index: 9999;
  animation: scan 8s linear infinite;
}

/* CRT Flicker */
page::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(18, 16, 16, 0.1);
  opacity: 0;
  pointer-events: none;
  z-index: 9998;
  animation: flicker 0.15s infinite;
}

@keyframes scan {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(10px);
  }
}

@keyframes flicker {
  0% {
    opacity: 0.27861;
  }
  5% {
    opacity: 0.34769;
  }
  10% {
    opacity: 0.23604;
  }
  15% {
    opacity: 0.90626;
  }
  20% {
    opacity: 0.18128;
  }
  25% {
    opacity: 0.83891;
  }
  30% {
    opacity: 0.65583;
  }
  35% {
    opacity: 0.67807;
  }
  40% {
    opacity: 0.26559;
  }
  45% {
    opacity: 0.84693;
  }
  50% {
    opacity: 0.96019;
  }
  55% {
    opacity: 0.08594;
  }
  60% {
    opacity: 0.20313;
  }
  65% {
    opacity: 0.71988;
  }
  70% {
    opacity: 0.53455;
  }
  75% {
    opacity: 0.37288;
  }
  80% {
    opacity: 0.71428;
  }
  85% {
    opacity: 0.70419;
  }
  90% {
    opacity: 0.7003;
  }
  95% {
    opacity: 0.36108;
  }
  100% {
    opacity: 0.24387;
  }
}

/* Phosphor Glow Effect */
@keyframes glow {
  0%, 100% {
    text-shadow: 0 0 10px #00ff41, 0 0 20px #00ff41, 0 0 30px #00ff41;
  }
  50% {
    text-shadow: 0 0 5px #00ff41, 0 0 10px #00ff41, 0 0 15px #00ff41;
  }
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* Terminal Prompt Style */
.terminal-prompt {
  color: #00ff41;
  font-family: 'Courier New', 'Courier', monospace;
  text-shadow: 0 0 10px #00ff41;
}

.terminal-prompt::before {
  content: '> ';
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

/* Primary Button - Terminal Command */
.btn-primary {
  background: transparent;
  color: #00ff41;
  border: 2rpx solid #00ff41;
  border-radius: 0;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  font-family: 'Courier New', 'Courier', monospace;
  margin: 16rpx 0;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  box-shadow: 0 0 10px rgba(0, 255, 65, 0.5);
  transition: all 0.1s ease;
  position: relative;
}

.btn-primary::before {
  content: '[';
  position: absolute;
  left: 8rpx;
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.btn-primary::after {
  content: ']';
  position: absolute;
  right: 8rpx;
  color: #ff0080;
  text-shadow: 0 0 10px #ff0080;
}

.btn-primary:active {
  background: rgba(0, 255, 65, 0.1);
  box-shadow: 0 0 20px rgba(0, 255, 65, 0.8), inset 0 0 10px rgba(0, 255, 65, 0.2);
  transform: scale(0.98);
}

.btn-primary[disabled] {
  border-color: #1a3a1a;
  color: #1a3a1a;
  box-shadow: none;
  text-shadow: none;
}

.btn-primary[disabled]::before,
.btn-primary[disabled]::after {
  color: #1a3a1a;
  text-shadow: none;
}

/* Secondary Button - Alt Command */
.btn-secondary {
  background: transparent;
  color: #00ccff;
  border: 2rpx solid #00ccff;
  border-radius: 0;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  font-weight: bold;
  font-family: 'Courier New', 'Courier', monospace;
  margin: 16rpx 0;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  box-shadow: 0 0 8px rgba(0, 204, 255, 0.4);
  transition: all 0.1s ease;
}

.btn-secondary:active {
  background: rgba(0, 204, 255, 0.1);
  box-shadow: 0 0 15px rgba(0, 204, 255, 0.7);
  transform: scale(0.98);
}

.btn-secondary[disabled] {
  border-color: #0a2a2a;
  color: #0a2a2a;
  box-shadow: none;
}

/* Danger Button - Critical Command */
.btn-danger {
  background: transparent;
  color: #ff0080;
  border: 2rpx solid #ff0080;
  border-radius: 0;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  font-weight: bold;
  font-family: 'Courier New', 'Courier', monospace;
  margin: 16rpx 0;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  box-shadow: 0 0 8px rgba(255, 0, 128, 0.4);
  transition: all 0.1s ease;
  animation: pulse-danger 2s infinite;
}

@keyframes pulse-danger {
  0%, 100% {
    box-shadow: 0 0 8px rgba(255, 0, 128, 0.4);
  }
  50% {
    box-shadow: 0 0 15px rgba(255, 0, 128, 0.7);
  }
}

.btn-danger:active {
  background: rgba(255, 0, 128, 0.1);
  box-shadow: 0 0 20px rgba(255, 0, 128, 0.9);
}

/* Button Group */
.action-row {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.action-row .half {
  flex: 1;
  margin: 0;
}

/* Terminal Window Card */
.card {
  background: rgba(0, 20, 10, 0.8);
  border: 2rpx solid #00ff41;
  border-radius: 0;
  padding: 32rpx 24rpx;
  margin: 24rpx 0;
  box-shadow:
    0 0 20px rgba(0, 255, 65, 0.2),
    inset 0 0 30px rgba(0, 255, 65, 0.05);
  position: relative;
}

/* ASCII Border Top */
.card::before {
  content: '╔═══════════════════════════════════════╗';
  position: absolute;
  top: -2rpx;
  left: 0;
  right: 0;
  font-size: 16rpx;
  color: #00ff41;
  text-shadow: 0 0 5px #00ff41;
  overflow: hidden;
  white-space: nowrap;
  font-family: 'Courier New', 'Courier', monospace;
}

/* ASCII Border Bottom */
.card::after {
  content: '╚═══════════════════════════════════════╝';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  font-size: 16rpx;
  color: #00ff41;
  text-shadow: 0 0 5px #00ff41;
  overflow: hidden;
  white-space: nowrap;
  font-family: 'Courier New', 'Courier', monospace;
}

/* Typography */
.text-center {
  text-align: center;
}

.text-muted {
  color: #00aa33;
  font-size: 24rpx;
  text-shadow: 0 0 5px #00aa33;
}

.text-accent {
  color: #00ff41;
  font-weight: bold;
  text-shadow: 0 0 10px #00ff41;
}

/* Score Colors - Terminal Style */
.score-positive {
  color: #00ff41;
  font-weight: bold;
  text-shadow: 0 0 10px #00ff41;
}

.score-positive::before {
  content: '+';
}

.score-negative {
  color: #ff0080;
  font-weight: bold;
  text-shadow: 0 0 10px #ff0080;
}

.score-neutral {
  color: #00ccff;
  font-weight: bold;
  text-shadow: 0 0 8px #00ccff;
}

/* Terminal Divider */
.divider {
  height: 2rpx;
  background: #00ff41;
  margin: 24rpx 0;
  box-shadow: 0 0 5px #00ff41;
  position: relative;
}

.divider::before {
  content: '─────────────────────────────────────────';
  position: absolute;
  top: -12rpx;
  left: 0;
  color: #00ff41;
  font-size: 20rpx;
  text-shadow: 0 0 5px #00ff41;
}

/* Badge - Status Indicator */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: transparent;
  color: #00ff41;
  border: 2rpx solid #00ff41;
  font-size: 20rpx;
  font-weight: bold;
  font-family: 'Courier New', 'Courier', monospace;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  box-shadow: 0 0 8px rgba(0, 255, 65, 0.5);
}

/* Glitch Animation */
@keyframes glitch {
  0% {
    transform: translate(0);
  }
  20% {
    transform: translate(-2rpx, 2rpx);
  }
  40% {
    transform: translate(-2rpx, -2rpx);
  }
  60% {
    transform: translate(2rpx, 2rpx);
  }
  80% {
    transform: translate(2rpx, -2rpx);
  }
  100% {
    transform: translate(0);
  }
}

.glitch {
  animation: glitch 0.3s infinite;
}

/* Loading Animation - Terminal Style */
@keyframes blink {
  0%, 49% {
    opacity: 1;
  }
  50%, 100% {
    opacity: 0;
  }
}

.loading::after {
  content: '█';
  animation: blink 1s infinite;
  color: #00ff41;
  text-shadow: 0 0 10px #00ff41;
}

/* Cursor Effect */
.cursor::after {
  content: '█';
  animation: blink 0.7s infinite;
  color: #00ff41;
  text-shadow: 0 0 10px #00ff41;
  margin-left: 4rpx;
}
