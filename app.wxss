/* app.wxss - Hugo Shell Retro Theme */

/* Pure terminal aesthetic - black background, green text, monospace font */

page {
  background: #000000;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
  color: #00ff00;
  font-size: 28rpx;
  line-height: 1.6;
}

view, text, button, input, image {
  box-sizing: border-box;
}

/* Container */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* Card - Terminal window with border */
.card {
  background: #000000;
  border: 2rpx solid #00ff00;
  padding: 32rpx;
  margin: 24rpx 0;
}

/* Buttons - Underlined terminal link style */
.btn-primary,
.btn-secondary,
.btn-danger,
button {
  background: transparent;
  color: #00ff00;
  border: none;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
  text-align: center;
  text-decoration: underline;
  cursor: pointer;
  display: block;
  width: 100%;
  margin: 16rpx 0;
  transition: color 0.2s ease;
}

.btn-primary::before {
  content: '> ';
  text-decoration: none;
  margin-right: 8rpx;
}

.btn-primary:active,
.btn-secondary:active,
.btn-danger:active,
button:active {
  color: #00dd00;
}

.btn-primary[disabled],
.btn-secondary[disabled],
.btn-danger[disabled] {
  color: #008800;
  text-decoration: line-through;
}

/* Button Row */
.action-row {
  display: flex;
  gap: 20rpx;
  margin: 16rpx 0;
}

.action-row .btn-primary,
.action-row .btn-secondary,
.action-row .btn-danger,
.action-row button {
  flex: 1;
  margin: 0;
}

.half {
  flex: 1;
}

/* Input fields - Terminal style */
input,
.input {
  background: #000000;
  border: 2rpx solid #00ff00;
  color: #00ff00;
  padding: 20rpx;
  font-size: 28rpx;
  font-family: 'Courier New', 'Courier', 'Monaco', 'Menlo', monospace;
  width: 100%;
  box-sizing: border-box;
}

input:focus,
.input:focus {
  outline: none;
  border-color: #00dd00;
}

input::placeholder {
  color: #008800;
}

/* Typography */
.text-center {
  text-align: center;
}

.text-muted {
  color: #008800;
  font-size: 24rpx;
}

.text-accent {
  color: #00ff00;
  font-weight: bold;
}

/* Score Colors - Use green shades */
.score-positive {
  color: #00ff00;
  font-weight: bold;
}

.score-positive::before {
  content: '+';
}

.score-negative {
  color: #008800;
  font-weight: bold;
}

.score-neutral {
  color: #00ff00;
  font-weight: bold;
}

/* Divider - Terminal separator */
.divider {
  border-bottom: 2rpx solid #00ff00;
  margin: 32rpx 0;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: transparent;
  color: #00ff00;
  border: 2rpx solid #00ff00;
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 0.1em;
}

/* Blinking cursor animation */
@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.cursor::after {
  content: '█';
  animation: blink 1s infinite;
  margin-left: 4rpx;
}

/* Images - Terminal border */
image {
  border: 2rpx solid #00ff00;
  display: block;
}

/* Modal overlays */
.modal-overlay {
  background: rgba(0, 0, 0, 0.95);
}

/* Scrollbars */
::-webkit-scrollbar {
  width: 8rpx;
}

::-webkit-scrollbar-track {
  background: #000000;
}

::-webkit-scrollbar-thumb {
  background: #00ff00;
  border: 1rpx solid #000000;
}

/* Tree structure decorations */
.tree-item::before {
  content: '├── ';
  color: #00ff00;
}

.tree-item:last-child::before {
  content: '└── ';
}

/* Links */
.link {
  color: #00ff00;
  text-decoration: underline;
}

.link:active {
  color: #00dd00;
}

/* Status indicators */
.status-online::before {
  content: '[ONLINE] ';
  color: #00ff00;
}

.status-offline::before {
  content: '[OFFLINE] ';
  color: #008800;
}

/* Fade in animation - minimal */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}
