/* app.wxss - Claude.ai 风格配色 */
page {
  background: linear-gradient(135deg, #FAF7F5 0%, #F5EDE6 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  min-height: 100vh;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #D97757 0%, #C95B3C 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(217, 119, 87, 0.25);
  transition: all 0.3s ease;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: white;
  color: #D97757;
  border: 2rpx solid #E8D5CB;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background-color: #FAF7F5;
  transform: scale(0.98);
}

.btn-danger {
  background: linear-gradient(135deg, #E85D5D 0%, #D94545 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(232, 93, 93, 0.25);
  transition: all 0.3s ease;
}

.btn-danger:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #9B8B7E;
  font-size: 24rpx;
}

.card {
  background-color: white;
  border-radius: 20rpx;
  padding: 36rpx;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(217, 119, 87, 0.08);
  transition: all 0.3s ease;
}
