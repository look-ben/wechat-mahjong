/* app.wxss - Minimalist Design */

/* Clean, simple, focused on content with generous whitespace */

page {
  background: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.6;
  padding: 0;
}

view, text, button, input, image {
  box-sizing: border-box;
}

/* Container with generous spacing */
.container {
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

/* Card - Simple with subtle border */
.card {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  padding: 40rpx 32rpx;
  margin: 32rpx 0;
}

/* Buttons - Minimal style */
.btn-primary,
.btn-secondary,
.btn-danger,
button {
  background: #1a1a1a;
  color: #ffffff;
  border: none;
  padding: 28rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  margin: 20rpx 0;
  transition: opacity 0.2s ease;
}

.btn-primary:active,
.btn-secondary:active,
.btn-danger:active,
button:active {
  opacity: 0.7;
}

.btn-secondary {
  background: #ffffff;
  color: #1a1a1a;
  border: 1rpx solid #1a1a1a;
}

.btn-danger {
  background: #ffffff;
  color: #d32f2f;
  border: 1rpx solid #d32f2f;
}

.btn-primary[disabled],
.btn-secondary[disabled],
.btn-danger[disabled] {
  background: #f5f5f5;
  color: #999999;
  border: 1rpx solid #e5e5e5;
  opacity: 0.5;
}

/* Button Row */
.action-row {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.action-row .btn-primary,
.action-row .btn-secondary,
.action-row .btn-danger,
.action-row button {
  flex: 1;
  margin: 0;
}

.half {
  flex: 1;
}

/* Input fields - Clean and simple */
input,
.input {
  background: #ffffff;
  border: none;
  border-bottom: 1rpx solid #e5e5e5;
  color: #1a1a1a;
  padding: 24rpx 0;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

input:focus,
.input:focus {
  outline: none;
  border-bottom-color: #1a1a1a;
}

input::placeholder {
  color: #999999;
}

/* Typography */
.text-center {
  text-align: center;
}

.text-muted {
  color: #999999;
  font-size: 24rpx;
}

.text-accent {
  color: #1a1a1a;
  font-weight: 500;
}

/* Score Colors - Minimal palette */
.score-positive {
  color: #1a1a1a;
  font-weight: 500;
}

.score-positive::before {
  content: '+';
}

.score-negative {
  color: #666666;
  font-weight: 500;
}

.score-neutral {
  color: #1a1a1a;
  font-weight: 500;
}

/* Divider - Thin line */
.divider {
  height: 1rpx;
  background: #e5e5e5;
  margin: 48rpx 0;
  border: none;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  color: #666666;
  border: none;
  font-size: 22rpx;
  font-weight: 500;
}

/* Images - Clean, no border */
image {
  display: block;
  border: none;
}

/* Modal overlays */
.modal-overlay {
  background: rgba(255, 255, 255, 0.95);
}

/* Scrollbars - Minimal */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: #ffffff;
}

::-webkit-scrollbar-thumb {
  background: #e5e5e5;
}

/* Links */
.link {
  color: #1a1a1a;
  text-decoration: none;
  border-bottom: 1rpx solid #1a1a1a;
}

.link:active {
  opacity: 0.7;
}

/* Fade in animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}
