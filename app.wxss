/* app.wxss - AI Workflows Inspired Design */

/* Design Philosophy:
   Modern AI/Tech interface with dark gradients, grid patterns, and glass morphism
   Clean, professional, with subtle animations and depth
*/

page {
  background: linear-gradient(180deg, #1a1d29 0%, #0f1117 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  min-height: 100vh;
  color: #ffffff;
  position: relative;
  overflow-x: hidden;
}

/* Grid Pattern Overlay */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
  z-index: 1;
}

/* Subtle Gradient Overlay */
page::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.1), transparent 50%);
  pointer-events: none;
  z-index: 1;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

/* Glass Morphism Card */
.card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin: 24rpx 0;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

/* Primary Button - Modern Style */
.btn-primary {
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0;
  box-shadow:
    0 8rpx 24rpx rgba(139, 92, 246, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow:
    0 4rpx 16rpx rgba(139, 92, 246, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary[disabled] {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
  box-shadow: none;
}

/* Secondary Button */
.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.98);
}

.btn-secondary[disabled] {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.1);
}

/* Danger Button */
.btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-danger:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
}

/* Button Row */
.action-row {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.action-row .half {
  flex: 1;
  margin: 0;
}

/* Typography */
.text-center {
  text-align: center;
}

.text-muted {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.text-accent {
  color: #fbbf24;
  font-weight: 600;
}

/* Score Colors */
.score-positive {
  color: #10b981;
  font-weight: 600;
}

.score-positive::before {
  content: '+';
}

.score-negative {
  color: #ef4444;
  font-weight: 600;
}

.score-neutral {
  color: #8b5cf6;
  font-weight: 600;
}

/* Divider */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  margin: 24rpx 0;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: rgba(139, 92, 246, 0.2);
  color: #a78bfa;
  border: 1px solid rgba(139, 92, 246, 0.3);
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 12rpx;
  letter-spacing: 0.05em;
}

/* Loading Animation */
@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.loading {
  position: relative;
  overflow: hidden;
}

.loading::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  animation: shimmer 1.5s infinite;
}

/* Fade In Animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.4s ease-out;
}
