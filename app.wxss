/* app.wxss - Travel App 清新风格 */
page {
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F9FB 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #4ECDC4 0%, #44A8A0 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.25);
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #D4D4D4 0%, #BCBCBC 100%);
  color: #999;
  box-shadow: none;
}

.btn-secondary {
  background-color: white;
  color: #44A8A0;
  border: 2rpx solid rgba(78, 205, 196, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background-color: #E8F4F8;
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn-secondary[disabled] {
  background-color: #f5f5f5;
  color: #bbb;
  border-color: #e0e0e0;
  box-shadow: none;
}

.btn-danger {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A52 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.btn-danger:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.25);
}

/* 按钮组布局 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin: 16rpx 0;
}

.action-row .half {
  flex: 1;
  margin: 0;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #7A9CA5;
  font-size: 24rpx;
}

.card {
  background-color: white;
  border-radius: 28rpx;
  padding: 40rpx;
  margin: 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.1);
  border: 1rpx solid rgba(78, 205, 196, 0.1);
  transition: all 0.3s ease;
}
